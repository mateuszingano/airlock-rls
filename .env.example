# Copy to .env and fill in. Get the URL from `supabase status` (local) or your
# project's connection string (Supabase dashboard → Project Settings → Database).
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Optional: comma-separated policy names that are intentionally permissive
# (e.g. a public status page). These won't fail the audit.
# RLS_AUDIT_ALLOW=public_read,status_select
