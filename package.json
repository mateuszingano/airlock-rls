{
  "name": "airlock-rls",
  "version": "0.2.1",
  "description": "The CI gate for Supabase RLS. Fails your build if a table ships without Row Level Security or a policy is permissive (USING (true)) — and scans your deployed site for an exposed service_role key.",
  "type": "module",
  "bin": {
    "airlock": "bin/airlock.mjs",
    "airlock-rls": "bin/airlock.mjs"
  },
  "types": "./src/audit.d.ts",
  "exports": {
    ".": {
      "types": "./src/audit.d.ts",
      "default": "./src/audit.mjs"
    }
  },
  "files": [
    "bin",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node bin/airlock.mjs",
    "test": "node --test",
    "prepublishOnly": "node --test"
  },
  "keywords": [
    "supabase",
    "postgres",
    "rls",
    "row-level-security",
    "security",
    "ci",
    "ci-gate",
    "github-action"
  ],
  "engines": {
    "node": ">=18"
  },
  "author": "Mateus Zingano",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mateuszingano/airlock-rls.git"
  },
  "bugs": {
    "url": "https://github.com/mateuszingano/airlock-rls/issues"
  },
  "homepage": "https://github.com/mateuszingano/airlock-rls#readme",
  "license": "MIT",
  "dependencies": {
    "pg": "^8.13.0"
  }
}
